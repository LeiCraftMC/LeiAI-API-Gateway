{
	"name": "ai-api-load-balancer",
	"version": "1.0.0",
	"description": "OpenAI-compatible API load balancer with SOCKS5 support",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"typecheck": "tsc -p ./tsconfig/tsconfig.typecheck.json && echo 'Typecheck passed!'",
		"test": "bun test",
		"dev": "bun run --watch src/index.ts",
		"compile": "bun run ./scripts/compile/index.ts",
		"start": "bun run scripts/entrypoint.ts"
	},
	"dependencies": {
		"socks": "^2.8.1"
	},
	"devDependencies": {
		"@cleverjs/cli": "^2.4.0",
		"bun-types": "latest",
		"@types/bun": "latest"
	},
	"private": true,
	"peerDependencies": {
		"typescript": "^5"
	}
}